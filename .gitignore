# -----------------------------------------------------------------------------
# Docker & Containers
# -----------------------------------------------------------------------------
# Ignore local docker data volumes (persisted data)
infra/docker/*/data/
infra/docker/*/logs/
*.db  # Ignore SQLite files (like superset.db if it reappears)

# But DO track docker-compose.yml and config files
!docker-compose.yml
!infra/docker/*/config/
!infra/docker/*/init/

