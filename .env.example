# ==============================================================================
# RETALSENSE LOCAL ENVIRONMENT (Development)
# ==============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Security & Secrets (Development Defaults - CHANGE FOR PRODUCTION!)
# ─────────────────────────────────────────────────────────────────────────────

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

HIVE_DB_USER=hive
HIVE_DB_PASSWORD=hive

# Generate a random key for Superset
SUPERSET_SECRET_KEY=change-this-in-production
SQLALCHEMY_DATABASE_URI=postgresql://superset:superset@postgres:5432/superset

# ─────────────────────────────────────────────────────────────────────────────
# Application Configuration (Development Defaults)
# ─────────────────────────────────────────────────────────────────────────────

PRODUCER_LOG_LEVEL=DEBUG
PRODUCER_INSTANCE_ID=producer-local
PRODUCER_RATE=100
BATCH_SIZE=100
NUM_STORES=3
NUM_ZONES_PER_STORE=4
TIMEZONE=Europe/Madrid

BRIDGE_LOG_LEVEL=DEBUG
BRIDGE_INSTANCE_ID=bridge-local

PROCESSOR_LOG_LEVEL=DEBUG
PROCESSOR_INSTANCE_ID=processor-local
SPARK_EXECUTOR_MEMORY=2g
SPARK_DRIVER_MEMORY=1g
SPARK_CORES_MAX=4
SPARK_SHUFFLE_PARTITIONS=200
WATERMARK_DELAY=10 minutes
AGGREGATION_WINDOW=5 minutes
TRIGGER_INTERVAL=5 seconds

# In development, we allow data loss (e.g., if topic is recreated)
KAFKA_FAIL_ON_DATA_LOSS=false

DLQ_ENABLED=false
AWS_REGION=us-east-1
TRINO_MEMORY_HEAP_SIZE=1g